{
  "name": "Blueflare-Sandbox",
  "dockerComposeFile": "docker-compose.yaml",
  "service": "app",
  "workspaceFolder": "/workspaces/sandbox",
  "mounts": [
    "source=claude-sandbox-auth,target=/home/utakata/.claude,type=volume",
    "source=sandbox-gh-auth,target=/home/utakata/.config/gh,type=volume",
    "source=sandbox-gemini-auth,target=/home/utakata/.gemini,type=volume",
    "source=sandbox-codex-auth,target=/home/utakata/.codex,type=volume"
  ],
  "remoteEnv": {
    "JJ_USER": "${localEnv:JJ_USER}",
    "JJ_EMAIL": "${localEnv:JJ_EMAIL}"
  },
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "forwardPorts": [5150],
  "remoteUser": "utakata",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.mouseWheelScrollSensitivity": 1
      },
      "extensions": [
        "MermaidChart.vscode-mermaid-chart",
        "visualjj.visualjj",
        "Zerotaskx.rust-extension-pack"
      ]
    }
  }
}
