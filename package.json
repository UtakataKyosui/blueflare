{
  "name": "blueflare",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbopack -H 0.0.0.0 -p 8787",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "preview": "sh scripts/opennext.sh build && bunx wrangler dev --ip 0.0.0.0 --remote",
    "deploy": "sh scripts/opennext.sh build && sh scripts/opennext.sh deploy",
    "upload": "sh scripts/opennext.sh build && sh scripts/opennext.sh upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@better-auth/drizzle-adapter": "^1.5.5",
    "@cloudflare/ai": "^1.2.2",
    "@huggingface/transformers": "^3.8.1",
    "@opennextjs/cloudflare": "^1.17.1",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.74.0"
  }
}